PORT=3000
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_SEC=28800

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=alfakhir
TYPEORM_SYNC=true
TYPEORM_LOG=false

# Premier demarrage : roles, categories, admin. Pour changer login/mdp d'un admin existant :
# SEED_ENSURE_ADMIN_CREDENTIALS=true puis redemarrer l'API une fois, puis remettre a false
SEED_ADMIN=true
SEED_ENSURE_ADMIN_CREDENTIALS=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
BCRYPT_ROUNDS=10
